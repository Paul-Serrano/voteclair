APP_NAME=VoteClair
APP_ENV=staging
APP_KEY=base64:AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA=
APP_DEBUG=false
APP_URL=https://staging.voteclair.example
API_VERSION=1.0.0-beta

APP_LOCALE=fr
APP_FALLBACK_LOCALE=fr
APP_FAKER_LOCALE=fr_FR

APP_MAINTENANCE_DRIVER=file

LOG_CHANNEL=stderr
LOG_STACK=stderr
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=info
LOG_DAILY_DAYS=14
VOTECLAIR_LOG_CHANNEL=stderr

DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=voteclair_staging
DB_USERNAME=voteclair
DB_PASSWORD=change-me

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=redis
CACHE_PREFIX=voteclair-staging

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

CLAIR_API_BASE_URL=https://clair-production.up.railway.app
CLAIR_API_CONNECT_TIMEOUT=10
CLAIR_API_TIMEOUT=30
CLAIR_API_MAX_ATTEMPTS=4
CLAIR_API_BACKOFF_MS=1000
CLAIR_API_THROTTLE_MS=6500
CLAIR_API_PAGE_SIZE=100
CLAIR_API_MAX_PAGES=500
CLAIR_API_INCREMENTAL_RECENT_PAGES=5
CLAIR_SYNC_CHAMBER=assemblee
CLAIR_SYNC_BATCH_SIZE=100
CLAIR_SYNC_VOTES_LIMIT=0

MAIL_MAILER=smtp
MAIL_SCHEME=tls
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=voteclair
MAIL_PASSWORD=change-me
MAIL_FROM_ADDRESS=hello@voteclair.example
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=eu-west-3
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"